APP_ENV=dev
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
ANALYSIS_ADAPTER=mock
AI_ENDPOINT=
AI_REQUEST_TIMEOUT_SECONDS=180
# example for local mock-ai container:
# AI_ENDPOINT=http://mock-ai:8090/analyze
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=admin123
SESSION_TTL_MINUTES=30
# 默认首项 * 与代码一致；生产去掉 *，或显式列 http://IP:7010,http://IP:7011 等。
CORS_ALLOWED_ORIGINS=*,http://localhost:3000,http://localhost:3001,http://localhost:8080,http://127.0.0.1:8080,http://localhost:7010,http://127.0.0.1:7010,http://localhost:7011,http://127.0.0.1:7011,http://localhost:7012,http://127.0.0.1:7012

# 可选：本地把 frontend-admin、frontend-student 复指到同一父目录下的 admin、student 子目录后，设置 STATIC_DIR=/path/to/parent（与 Docker 中 /srv/static 结构一致）
STATIC_DIR=

# PostgreSQL (pgx) example — URL form required:
# DB_DSN=postgres://stepup_user:stepup_pass@127.0.0.1:5432/stepup?sslmode=disable
DB_DSN=
