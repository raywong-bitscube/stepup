APP_ENV=dev
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
ANALYSIS_ADAPTER=mock
AI_ENDPOINT=
AI_REQUEST_TIMEOUT_SECONDS=30
# example for local mock-ai container:
# AI_ENDPOINT=http://mock-ai:8090/analyze
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=admin123
ADMIN_SESSION_TTL_HOURS=24
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080,http://127.0.0.1:8080

# 可选：本地把 frontend-admin、frontend-student 复指到同一父目录下的 admin、student 子目录后，设置 STATIC_DIR=/path/to/parent（与 Docker 中 /srv/static 结构一致）
STATIC_DIR=

# MySQL example:
# DB_DSN=stepup_user:stepup_pass@tcp(127.0.0.1:3306)/stepup?charset=utf8mb4&parseTime=True&loc=Local
DB_DSN=
