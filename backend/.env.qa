# StepUp 后端 — QA / 测试（本地直接 go run，非 Docker Compose）
# 用法示例（在仓库根目录）：
#   set -a && source backend/.env.qa && set +a && go run ./backend/cmd/server
# 或：export $(grep -v '^#' backend/.env.qa | xargs)   # 注意值中含空格时需调整
# 请勿提交填好真实密码后的本文件；可与根目录 .env.qa 中数据库账号保持一致。

APP_ENV=staging
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

ANALYSIS_ADAPTER=http
AI_ENDPOINT=
AI_REQUEST_TIMEOUT_SECONDS=180

ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_ADMIN_PASS
SESSION_TTL_MINUTES=30

# 与浏览器页面 Origin 一致（逗号分隔）。分端口示例：http://IP:7010,http://IP:7011（非 API 端口）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080,http://127.0.0.1:8080,http://localhost:7010,http://127.0.0.1:7010,http://localhost:7011,http://127.0.0.1:7011,http://localhost:7012,http://127.0.0.1:7012

# 可选：本地静态页整合调试，指向含 admin/、student/ 子目录的父路径
STATIC_DIR=

# 必填：QA 库 DSN（PostgreSQL URL，与根目录 .env.qa 中 POSTGRES_* 一致时可本地转发端口后连接）
# 例：postgres://user:pass@127.0.0.1:5432/stepup_qa?sslmode=disable
DB_DSN=postgres://CHANGE_ME_USER:CHANGE_ME_PASS@127.0.0.1:5432/stepup_qa?sslmode=disable
