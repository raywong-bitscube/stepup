APP_ENV=dev
# 使用库内 DeepSeek 种子模型时请设为 http（会读 ai_model 激活行）
ANALYSIS_ADAPTER=http
AI_ENDPOINT=
AI_REQUEST_TIMEOUT_SECONDS=180
MOCK_AI_PORT=8090

MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=stepup
MYSQL_USER=stepup_user
MYSQL_PASSWORD=stepup_pass
MYSQL_PORT=3306

BACKEND_PORT=8080
STUDENT_PORT=3000
ADMIN_PORT=3001

ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=admin123
# Admin + student login session lifetime (minutes). Legacy: ADMIN_SESSION_TTL_HOURS still supported if this is unset.
SESSION_TTL_MINUTES=30

# 浏览器跨域：须与地址栏 Origin 完全一致（协议+主机+端口，无末尾 /）。
# 学生端与管理端是不同 Origin，白名单要同时写两个页面入口，不能只配管理页。
# 分端口（学生 :7010、管理 :7011、API :7012）公网/LAN 示例：
# CORS_ALLOWED_ORIGINS=http://203.0.113.50:7010,http://203.0.113.50:7011
# Compose 默认静态（学生 :3000、管理 :3001、API :8080）用 IP 访问时示例：
# CORS_ALLOWED_ORIGINS=http://203.0.113.50:3000,http://203.0.113.50:3001
# 本地开发：
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080,http://127.0.0.1:8080
# Docker 镜像内由后端挂载 /admin/、/student/；本地 go run 可设为仓库绝对路径，如 STATIC_DIR=/path/to/stepup/static-bundle
STATIC_DIR=
